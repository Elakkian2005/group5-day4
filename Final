<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>StudentPro — UCSC Hub</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    :root {
      --maroon:       #8B0000;
      --maroon-deep:  #5a0000;
      --maroon-light: #a52020;
      --gold:         #CFB53B;
      --gold-light:   #e8d06a;
      --gold-pale:    #fdf6da;
      --btn:          var(--maroon);
      --btn-h:        var(--maroon-deep);
      --card-bg-solid: rgba(255,255,255,0.98);
      --sidebar-item:  rgba(255,255,255,0.13);
      --sidebar-item-h:rgba(207,181,59,0.25);
      --radius: 20px;
      --radius-sm: 12px;
    }

    body {
      font-family: 'Outfit', sans-serif;
      min-height: 100vh;
      background: linear-gradient(135deg, #3b0000 0%, #8B0000 50%, #b84c00 100%);
      background-attachment: fixed;
      color: #fff;
      overflow-x: hidden;
      animation: pageFadeIn 0.7s ease both;
    }
    @keyframes pageFadeIn {
      from { opacity:0; }
      to   { opacity:1; }
    }

    /* ── NAVBAR ── */
    .navbar {
      position: sticky; top:0; z-index:100;
      background: rgba(60,0,0,0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 2px solid rgba(207,181,59,0.4);
      padding: 0 32px;
      height: 68px;
      display: flex; align-items: center; justify-content: space-between;
      animation: slideDown 0.5s ease both;
    }
    @keyframes slideDown {
      from { opacity:0; transform:translateY(-20px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .brand { display:flex; align-items:center; gap:10px; }
    .brand-logo { display:flex; align-items:center; }
    .brand-logo img { width:52px; height:52px; object-fit:contain; border-radius:12px; }
    .brand-name { font-family:'Nunito',sans-serif; font-size:22px; font-weight:900; color:#fff; letter-spacing:-0.3px; }
    .nav-tabs {
      display:flex; gap:6px;
      background:rgba(0,0,0,0.25);
      padding:6px; border-radius:14px;
      border:1px solid rgba(207,181,59,0.2);
    }
    .nav-tab {
      padding:8px 18px; border-radius:10px; border:none;
      background:transparent; color:rgba(255,255,255,0.65);
      font-family:'Outfit',sans-serif; font-size:13px; font-weight:600;
      cursor:pointer; transition:all 0.25s; white-space:nowrap;
    }
    .nav-tab:hover { color:#fff; background:rgba(207,181,59,0.15); }
    .nav-tab.active {
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: var(--maroon);
      font-weight:800;
      box-shadow:0 4px 14px rgba(207,181,59,0.45);
    }

    /* ── LAYOUT ── */
    .layout { display:flex; min-height:calc(100vh - 68px); }

    /* ── SIDEBAR ── */
    .sidebar { width:260px; min-width:260px; padding:28px 18px; display:flex; flex-direction:column; gap:10px; }
    .sidebar-label {
      font-family:'Nunito',sans-serif; font-size:11px; font-weight:800;
      letter-spacing:2px; text-transform:uppercase;
      color:var(--gold-light); margin-bottom:6px; padding-left:4px;
      opacity:0; animation: fadeUp 0.5s ease 0.2s both;
    }
    .task-card {
      background:var(--sidebar-item);
      backdrop-filter:blur(10px);
      border:1px solid rgba(207,181,59,0.2);
      border-radius:var(--radius-sm);
      padding:14px 16px; cursor:pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease, border-color 0.3s ease;
      opacity:0;
      animation:fadeUp 0.5s ease both;
    }
    .task-card:nth-child(2){animation-delay:0.15s}
    .task-card:nth-child(3){animation-delay:0.25s}
    .task-card:nth-child(4){animation-delay:0.35s}
    .task-card:nth-child(5){animation-delay:0.45s}
    .task-card:nth-child(6){animation-delay:0.55s}
    .task-card:hover {
      background: rgba(207,181,59,0.18);
      transform: translateX(6px) scale(1.03);
      border-color: var(--gold);
      box-shadow: 0 0 16px rgba(207,181,59,0.45), 0 4px 18px rgba(0,0,0,0.2);
    }
    .task-card-title { font-size:14px; font-weight:700; color:#fff; }
    .task-card-date  { font-size:12px; color:rgba(255,255,255,0.5); margin-top:3px; }
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(14px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* ── MAIN ── */
    .main { flex:1; padding:32px 36px; display:flex; align-items:flex-start; justify-content:center; }
    .section { display:none; width:100%; max-width:580px; }
    .section.active { display:block; animation: sectionFadeIn 0.45s ease both; }
    @keyframes sectionFadeIn {
      from { opacity:0; transform:translateY(18px) scale(0.99); }
      to   { opacity:1; transform:translateY(0)    scale(1); }
    }

    /* ── WHITE CARD ── */
    .white-card {
      background:var(--card-bg-solid);
      border-radius:var(--radius);
      padding:36px 40px;
      box-shadow:0 20px 60px rgba(0,0,0,0.25), 0 0 0 1px rgba(207,181,59,0.2);
      color:#1a0a0a;
    }
    .white-card h2 {
      font-family:'Nunito',sans-serif; font-size:22px; font-weight:900;
      color:var(--maroon); margin-bottom:24px;
      display:flex; align-items:center; gap:10px;
      padding-bottom:14px;
      border-bottom: 2px solid var(--gold-pale);
    }

    /* ── INPUTS ── */
    input[type="text"],input[type="number"],select,textarea {
      width:100%; padding:10px 14px;
      border:1.5px solid #e8d8c8; border-radius:10px;
      font-family:'Outfit',sans-serif; font-size:14px;
      color:#2a0a0a; background:#fffaf5; transition:border 0.2s,box-shadow 0.2s;
    }
    input:focus,select:focus,textarea:focus {
      outline:none; border-color:var(--maroon);
      box-shadow:0 0 0 3px rgba(139,0,0,0.1);
    }

    /* ── BUTTONS ── */
    .btn-primary {
      background: linear-gradient(135deg, var(--maroon), var(--maroon-light));
      color:#fff; border:none;
      padding:12px 28px; border-radius:12px;
      font-family:'Nunito',sans-serif; font-size:15px; font-weight:800;
      cursor:pointer; transition:all 0.25s;
      box-shadow:0 6px 20px rgba(139,0,0,0.35); letter-spacing:0.2px;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, var(--maroon-deep), var(--maroon));
      transform:translateY(-2px); box-shadow:0 8px 24px rgba(139,0,0,0.5);
    }
    .btn-ghost {
      background: var(--gold-pale); color: var(--maroon);
      border:1.5px solid var(--gold); padding:10px 20px; border-radius:10px;
      font-family:'Outfit',sans-serif; font-size:13px; font-weight:600;
      cursor:pointer; transition:all 0.2s;
    }
    .btn-ghost:hover { background:#f5e98a; border-color: var(--gold-light); }

    /* ── GPA ── */
    .gpa-row { display:grid; grid-template-columns:100px 1fr 1fr 30px; gap:10px; align-items:center; margin-bottom:12px; }
    .gpa-row-label { font-size:12px; font-weight:700; color:#7a5a3a; }
    .del-btn { background:none; border:none; color:#ccc; font-size:16px; cursor:pointer; transition:color 0.2s; }
    .del-btn:hover { color:#e00; }
    .gpa-actions { display:flex; gap:10px; margin-top:16px; }
    .result-card {
      margin-top:20px; padding:20px;
      background: linear-gradient(135deg, #fff8e8, #fff3d4);
      border:2px solid var(--gold); border-radius:14px;
      text-align:center; display:none;
    }
    .result-gpa { font-family:'Nunito',sans-serif; font-size:44px; font-weight:900; color:var(--maroon); line-height:1; }
    .result-level { font-size:15px; font-weight:700; color:#b8860b; margin-top:8px; }

    /* ── TIMER ── */
    .timer-modes { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:22px; }
    .mode-chip {
      padding:6px 16px; border-radius:20px;
      border:1.5px solid #e8d8c0; background:#fffaf5; color:#7a5a3a;
      font-size:12px; font-weight:700; cursor:pointer; transition:all 0.2s; font-family:'Outfit',sans-serif;
    }
    .mode-chip.active,.mode-chip:hover {
      background: linear-gradient(135deg, var(--maroon), var(--maroon-light));
      color:#fff; border-color:var(--maroon); box-shadow:0 4px 12px rgba(139,0,0,0.25);
    }
    .timer-face { display:flex; flex-direction:column; align-items:center; margin:10px 0 28px; }
    .timer-ring-wrap { position:relative; width:210px; height:210px; }
    .timer-ring-wrap svg { position:absolute; top:0; left:0; transform:rotate(-90deg); }
    .ring-bg   { fill:none; stroke:#f5e8d0; stroke-width:10; }
    .ring-prog { fill:none; stroke:url(#ringGrad); stroke-width:10; stroke-linecap:round; transition:stroke-dashoffset 1s linear; }
    .timer-inner { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; }
    .timer-digits { font-family:'Nunito',sans-serif; font-size:52px; font-weight:900; color:var(--maroon); letter-spacing:1px; line-height:1; }
    .timer-sub { font-size:12px; color:#9a7a5a; font-weight:600; margin-top:4px; }
    .timer-status-txt { font-size:13px; color:#9a7a5a; font-weight:500; margin-top:10px; }
    .timer-btns { display:flex; gap:16px; justify-content:center; align-items:center; }
    .t-icon-btn {
      width:58px; height:58px; border-radius:50%; border:none;
      display:flex; align-items:center; justify-content:center;
      cursor:pointer; transition:all 0.25s; font-size:20px;
    }
    .t-icon-btn:hover { transform:scale(1.1); }
    .t-play {
      width:68px; height:68px; font-size:24px;
      background: linear-gradient(135deg, var(--maroon), var(--maroon-light)); color:#fff;
      box-shadow:0 8px 24px rgba(139,0,0,0.4);
    }
    .t-play:hover { background: linear-gradient(135deg, var(--maroon-deep), var(--maroon)); box-shadow:0 10px 28px rgba(139,0,0,0.5); }
    .t-play.paused-state { background: linear-gradient(135deg,#15803d,#22c55e); box-shadow:0 8px 24px rgba(34,197,94,0.4); }
    .t-pause {
      background: var(--gold-pale); color: var(--maroon);
      border:2px solid var(--gold) !important;
    }
    .t-pause:hover { background:#f5e98a; }
    .t-reset {
      background:#fdf4f4; color:#c00;
      border:2px solid #f8dede !important;
    }
    .t-reset:hover { background:#fce8e8; }
    .timer-notify {
      display:none;
      background: linear-gradient(90deg, var(--maroon), var(--maroon-light));
      color:#fff; text-align:center; padding:12px; border-radius:12px;
      font-weight:700; font-family:'Nunito',sans-serif; margin-bottom:18px; animation:fadeUp 0.4s ease;
    }
    .sessions-row { text-align:center; margin-top:14px; font-size:13px; color:#9a7a5a; font-weight:600; }
    .session-dots { display:flex; gap:6px; justify-content:center; margin-top:6px; }
    .sdot { width:10px; height:10px; border-radius:50%; background:#f0dfc0; transition:background 0.3s; }
    .sdot.done { background: var(--maroon); }
    .custom-row { display:flex; gap:8px; align-items:center; margin-bottom:16px; }
    .custom-row label { font-size:13px; color:#9a7a5a; font-weight:600; white-space:nowrap; }
    .custom-row input { max-width:80px; }

    /* ── TODO ── */
    .todo-add { display:flex; gap:8px; margin-bottom:16px; }
    .todo-add input { flex:1; }
    .todo-filters { display:flex; gap:6px; margin-bottom:14px; flex-wrap:wrap; }
    .fchip {
      padding:5px 14px; border-radius:20px;
      border:1.5px solid #e8d8c0; background:#fffaf5; color:#9a7a5a;
      font-size:12px; font-weight:700; cursor:pointer; transition:all 0.2s; font-family:'Outfit',sans-serif;
    }
    .fchip.active {
      background: linear-gradient(135deg, var(--maroon), var(--maroon-light));
      color:#fff; border-color:var(--maroon);
    }
    .todo-stats { display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap; }
    .stat-pill { padding:4px 12px; border-radius:20px; background:var(--gold-pale); color:var(--maroon); font-size:12px; font-weight:700; border:1px solid var(--gold); }
    .todo-list { display:flex; flex-direction:column; gap:8px; max-height:320px; overflow-y:auto; padding-right:4px; }
    .todo-item {
      display:flex; align-items:center; gap:10px;
      padding:12px 14px; background:#fffaf5;
      border:1.5px solid #f0dfc0; border-radius:12px; transition:all 0.2s; animation:fadeUp 0.3s ease;
    }
    .todo-item:hover { border-color:var(--gold); box-shadow:0 2px 8px rgba(207,181,59,0.15); }
    .todo-item.done { opacity:0.5; }
    .todo-item.done .todo-text { text-decoration:line-through; color:#bbb; }
    .chk {
      width:22px; height:22px; border-radius:7px;
      border:2px solid #e0c89a; background:#fff; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      font-size:12px; color:#fff; flex-shrink:0; transition:all 0.2s;
    }
    .chk.on { background:var(--maroon); border-color:var(--maroon); }
    .todo-text { flex:1; font-size:14px; color:#2a0a0a; font-weight:500; }
    .pri-badge { font-size:10px; font-weight:800; padding:2px 9px; border-radius:10px; text-transform:uppercase; letter-spacing:0.5px; }
    .p-high { background:#ffe0e0; color:#c00; }
    .p-med  { background:#fff8e0; color:#a07000; }
    .p-low  { background:#e0f8e8; color:#1a7a3a; }
    .todo-del { background:none; border:none; color:#ddd; font-size:16px; cursor:pointer; transition:color 0.2s; }
    .todo-del:hover { color:#e00; }
    .empty-msg { text-align:center; color:#bbb; font-size:14px; padding:28px 0; }

    /* ── NOTES ── */
    .notes-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:12px;
      max-height:320px; overflow-y:auto; margin-bottom:16px;
    }
    .note-card {
      background:#fffaf5; border:1.5px solid #f0dfc0; border-radius:12px;
      padding:14px; cursor:pointer; transition:all 0.2s; position:relative; animation:fadeUp 0.3s ease;
    }
    .note-card:hover { border-color:var(--gold); transform:translateY(-2px); box-shadow:0 4px 14px rgba(207,181,59,0.2); }
    .note-card-title { font-weight:800; font-size:13px; color:var(--maroon); margin-bottom:5px; }
    .note-card-preview { font-size:12px; color:#9a7a5a; overflow:hidden; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; }
    .note-card-date { font-size:11px; color:#c0a888; margin-top:8px; }
    .note-del-x { position:absolute; top:8px; right:8px; background:none; border:none; font-size:14px; color:#ddd; cursor:pointer; }
    .note-del-x:hover { color:#e00; }
    .note-editor { display:none; flex-direction:column; gap:10px; }
    .note-editor.open { display:flex; }
    .note-editor textarea { min-height:120px; resize:vertical; line-height:1.6; }
    .note-editor-btns { display:flex; gap:8px; }

    /* ── TIMETABLE ── */
    .tt-add { display:grid; grid-template-columns:1fr 1fr 1fr 1fr auto; gap:8px; align-items:end; margin-bottom:20px; }
    .tt-add label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#9a7a5a; display:block; margin-bottom:4px; }
    .tt-wrap { overflow-x:auto; border-radius:14px; border:1.5px solid #f0dfc0; }
    .tt-grid { display:grid; grid-template-columns:72px repeat(5,1fr); font-size:11px; min-width:500px; }
    .tt-head { background:linear-gradient(135deg,var(--maroon),var(--maroon-light)); color:#fff; padding:10px 6px; text-align:center; font-weight:800; font-family:'Nunito',sans-serif; font-size:11px; }
    .tt-time { background:#fffaf5; padding:8px 6px; text-align:center; font-size:11px; color:#9a7a5a; font-weight:700; border-top:1px solid #f0dfc0; }
    .tt-cell { padding:4px; border-top:1px solid #f0dfc0; border-left:1px solid #f0dfc0; min-height:40px; background:#fff; }
    .tt-entry {
      background: linear-gradient(135deg, #fff8e8, var(--gold-pale));
      border:1px solid var(--gold); border-radius:6px;
      padding:4px 7px; font-size:11px; font-weight:700; color:var(--maroon);
      display:flex; justify-content:space-between; align-items:center; margin-bottom:2px;
    }
    .tt-entry-del { background:none; border:none; font-size:11px; color:#ccc; cursor:pointer; }
    .tt-entry-del:hover { color:#e00; }

    ::-webkit-scrollbar { width:5px; height:5px; }
    ::-webkit-scrollbar-track { background:transparent; }
    ::-webkit-scrollbar-thumb { background:#d0c8ea; border-radius:5px; }

    /* ── DARK MODE TOGGLE SWITCH ── */
    .toggle-wrap {
      display:flex; align-items:center; gap:8px; margin-left:12px;
    }
    .toggle-label {
      font-size:12px; font-weight:600; color:rgba(255,255,255,0.7);
      white-space:nowrap;
    }
    .toggle-switch {
      position:relative; width:46px; height:24px; cursor:pointer;
    }
    .toggle-switch input { opacity:0; width:0; height:0; }
    .toggle-track {
      position:absolute; inset:0;
      background:rgba(255,255,255,0.2);
      border-radius:34px;
      border:1.5px solid rgba(255,255,255,0.25);
      transition:background 0.3s, border-color 0.3s;
    }
    .toggle-thumb {
      position:absolute; top:3px; left:3px;
      width:16px; height:16px; border-radius:50%;
      background:#fff;
      transition:transform 0.3s, background 0.3s;
      display:flex; align-items:center; justify-content:center;
      font-size:10px; line-height:1;
    }
    .toggle-switch input:checked + .toggle-track { background:var(--maroon); border-color:var(--gold); }
    .toggle-switch input:checked ~ .toggle-thumb { transform:translateX(22px); background:#fff; }

    /* ── DARK MODE OVERRIDES ── */
    body.dark-mode {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a0808 50%, #0d0d0d 100%);
    }
    body.dark-mode .navbar {
      background: rgba(20,0,0,0.88);
      border-bottom-color: rgba(207,181,59,0.2);
    }
    body.dark-mode .nav-tabs {
      background: rgba(255,255,255,0.05);
      border-color: rgba(255,255,255,0.08);
    }
    body.dark-mode .nav-tab { color:rgba(255,255,255,0.5); }
    body.dark-mode .nav-tab:hover { background:rgba(207,181,59,0.1); color:#fff; }
    body.dark-mode .nav-tab.active { background:linear-gradient(135deg,#5a0000,#8B0000); color:var(--gold); box-shadow:0 4px 14px rgba(139,0,0,0.5); }
    body.dark-mode .sidebar {
      background: rgba(255,255,255,0.03);
    }
    body.dark-mode .white-card {
      background: #1e1e2e;
      color: #e0e0f0;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06);
    }
    body.dark-mode .white-card h2 { color:#e8a0a0; border-bottom-color:#2a1010; }
    body.dark-mode input[type="text"],
    body.dark-mode input[type="number"],
    body.dark-mode select,
    body.dark-mode textarea {
      background:#2a2a3e; color:#e0e0f0;
      border-color:#3a3a5c;
    }
    body.dark-mode input:focus,
    body.dark-mode select:focus,
    body.dark-mode textarea:focus {
      border-color:#6c63ff;
      box-shadow:0 0 0 3px rgba(108,99,255,0.2);
    }
    body.dark-mode .btn-ghost { background:#2a1010; color:#e8a0a0; border-color:#3a1a1a; }
    body.dark-mode .btn-ghost:hover { background:#3a1a1a; }
    body.dark-mode .gpa-row-label { color:#8a6a6a; }
    body.dark-mode .result-card { background:linear-gradient(135deg,#1e0808,#1a1000); border-color:#6a4a00; }
    body.dark-mode .result-gpa { color:#e8c060; }
    body.dark-mode .result-level { color:#CFB53B; }
    body.dark-mode .mode-chip { background:#2a1010; color:#8a6a6a; border-color:#3a1a1a; }
    body.dark-mode .timer-digits { color:#e8a0a0; }
    body.dark-mode .timer-sub, body.dark-mode .timer-status-txt, body.dark-mode .sessions-row { color:#6a4a4a; }
    body.dark-mode .ring-bg { stroke:#2a1010; }
    body.dark-mode .t-pause { background:#2a1010; border-color:#4a2a00 !important; color:#CFB53B; }
    body.dark-mode .t-reset { background:#2a0808; border-color:#4a1a1a !important; color:#f87171; }
    body.dark-mode .timer-notify { background:linear-gradient(90deg,#5a0000,#8B0000); }
    body.dark-mode .sdot { background:#2a1010; }
    body.dark-mode .todo-item { background:#2a1010; border-color:#3a1a1a; color:#e0c8c8; }
    body.dark-mode .todo-text { color:#e0c8c8; }
    body.dark-mode .stat-pill { background:#2a1010; color:#CFB53B; border-color:#4a3000; }
    body.dark-mode .fchip { background:#2a1010; color:#8a6a6a; border-color:#3a1a1a; }
    body.dark-mode .chk { background:#1e0808; border-color:#4a2a2a; }
    body.dark-mode .note-card { background:#2a1010; border-color:#3a1a1a; }
    body.dark-mode .note-card-title { color:#e8a0a0; }
    body.dark-mode .note-card-preview { color:#6a4a4a; }
    body.dark-mode .tt-head { background:linear-gradient(135deg,#5a0000,#8B0000); }
    body.dark-mode .tt-time { background:#2a1010; color:#6a4a4a; border-color:#3a1a1a; }
    body.dark-mode .tt-cell { background:#1e0808; border-color:#3a1a1a; }
    body.dark-mode .tt-entry { background:linear-gradient(135deg,#2a1000,#1e0808); border-color:#6a4a00; color:#e8c060; }
    body.dark-mode .tt-wrap { border-color:#3a1a1a; }
    body.dark-mode ::-webkit-scrollbar-thumb { background:#4a2a2a; }

    /* ── GROUP IDEA BOARD ── */
    .idea-board-wrap { width:100%; max-width:780px; }
    .idea-board-header {
      background: linear-gradient(135deg, var(--maroon) 0%, var(--maroon-light) 60%, #b84c00 100%);
      color: #fff;
      padding: 36px 40px;
      text-align: center;
      border-radius: var(--radius) var(--radius) 0 0;
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 30px rgba(139,0,0,0.35);
    }
    .idea-board-header::before {
      content: '';
      position: absolute; top: -40%; right: -20%; width: 60%; height: 160%;
      background: radial-gradient(circle, rgba(207,181,59,0.18) 0%, transparent 70%);
      animation: pulse 6s ease-in-out infinite;
    }
    .idea-board-header::after {
      content: '✨'; position: absolute; right: 32px; top: 16px;
      font-size: 28px; animation: float 3s ease-in-out infinite; opacity: 0.8;
    }
    .idea-board-logo {
      font-size: 48px; display: inline-block; margin-bottom: 10px;
      animation: spin 3s linear infinite;
      filter: drop-shadow(0 0 12px rgba(207,181,59,0.7));
    }
    @keyframes spin {
      0%   { transform: rotateY(0deg) scale(1); }
      50%  { transform: rotateY(180deg) scale(1.1); }
      100% { transform: rotateY(360deg) scale(1); }
    }
    .idea-board-title {
      font-family:'Nunito',sans-serif; font-size:26px; font-weight:900;
      letter-spacing: 2px; text-transform: uppercase; color:#fff;
      position: relative; z-index:2;
      text-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }
    .idea-stats-bar {
      display:flex; justify-content:space-around; align-items:center;
      padding: 22px 40px;
      background: rgba(90,0,0,0.55);
      backdrop-filter: blur(10px);
      border-bottom: 2px solid rgba(207,181,59,0.25);
      flex-wrap: wrap; gap: 20px;
    }
    .idea-stat-item {
      display:flex; flex-direction:column; align-items:center; gap:6px;
      padding: 12px 22px; border-radius: var(--radius-sm);
      background: rgba(207,181,59,0.1);
      border: 1px solid rgba(207,181,59,0.25);
      transition: all 0.3s ease;
    }
    .idea-stat-item:hover {
      transform: translateY(-3px);
      background: rgba(207,181,59,0.2);
      box-shadow: 0 6px 20px rgba(207,181,59,0.2);
    }
    .idea-stat-label { font-size:11px; color:var(--gold-light); text-transform:uppercase; letter-spacing:1.2px; font-weight:800; }
    .idea-stat-value { font-family:'Nunito',sans-serif; font-size:30px; font-weight:900; color:#fff; line-height:1; }
    .idea-clear-btn-wrap { display:flex; align-items:center; }
    .idea-clear-btn {
      padding: 10px 20px;
      background: linear-gradient(135deg, #8B0000, #c0392b);
      color:#fff; border:none; border-radius: var(--radius-sm);
      font-family:'Nunito',sans-serif; font-size:13px; font-weight:800;
      cursor:pointer; transition:all 0.25s; letter-spacing:0.5px;
      box-shadow: 0 4px 14px rgba(139,0,0,0.4);
      display:flex; align-items:center; gap:6px;
      position:relative; overflow:hidden;
    }
    .idea-clear-btn::before {
      content:''; position:absolute; top:0; left:-100%; width:100%; height:100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
      transition: left 0.5s;
    }
    .idea-clear-btn:hover::before { left:100%; }
    .idea-clear-btn:hover { transform:translateY(-2px); box-shadow:0 7px 22px rgba(139,0,0,0.55); }
    .idea-input-section {
      display:flex; flex-direction:column; gap:14px; padding:28px 32px;
      background: rgba(60,0,0,0.35);
      border-bottom: 2px solid rgba(207,181,59,0.18);
    }
    .idea-select-label { font-family:'Nunito',sans-serif; font-size:11px; font-weight:800; color:var(--gold-light); text-transform:uppercase; letter-spacing:1.5px; }
    .idea-input-row { display:flex; gap:12px; flex-wrap:wrap; align-items:center; }
    .idea-name-select {
      padding: 13px 18px;
      border: 1.5px solid rgba(207,181,59,0.4);
      border-radius: var(--radius-sm);
      font-family:'Outfit',sans-serif; font-size:14px; font-weight:700;
      color:#fff;
      background: rgba(40,0,0,0.7);
      cursor:pointer; min-width:220px;
      transition: all 0.25s;
      box-shadow: 0 4px 14px rgba(139,0,0,0.2);
      appearance: none;
      background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23CFB53B' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
      background-repeat: no-repeat;
      background-position: right 12px center;
      background-size: 18px;
      padding-right: 42px;
    }
    .idea-name-select option { background:#3a0000; color:#fff; font-weight:700; }
    .idea-name-select:hover, .idea-name-select:focus {
      border-color: var(--gold); outline:none;
      box-shadow: 0 0 0 3px rgba(207,181,59,0.2), 0 4px 14px rgba(207,181,59,0.2);
    }
    .idea-text-input {
      flex:1; padding:13px 18px;
      border: 1.5px solid rgba(207,181,59,0.3);
      border-radius: var(--radius-sm);
      font-family:'Outfit',sans-serif; font-size:14px; color:#fff;
      background: rgba(40,0,0,0.6);
      transition: all 0.25s; min-width:220px;
      box-shadow: 0 3px 10px rgba(0,0,0,0.2);
    }
    .idea-text-input::placeholder { color:rgba(255,255,255,0.35); }
    .idea-text-input:hover { border-color: rgba(207,181,59,0.6); }
    .idea-text-input:focus { outline:none; border-color:var(--gold); box-shadow:0 0 0 3px rgba(207,181,59,0.15); }
    .idea-add-btn {
      padding: 13px 32px;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: var(--maroon);
      border:none; border-radius: var(--radius-sm);
      font-family:'Nunito',sans-serif; font-size:14px; font-weight:900;
      cursor:pointer; transition:all 0.25s; white-space:nowrap;
      text-transform:uppercase; letter-spacing:1px;
      box-shadow: 0 6px 18px rgba(207,181,59,0.4);
      position:relative; overflow:hidden;
    }
    .idea-add-btn::before {
      content:''; position:absolute; top:0; left:-100%; width:100%; height:100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
      transition:left 0.5s;
    }
    .idea-add-btn:hover::before { left:100%; }
    .idea-add-btn:hover { transform:translateY(-3px); box-shadow:0 10px 28px rgba(207,181,59,0.55); }
    .ideas-feed {
      padding: 28px 32px; min-height:320px;
      background: rgba(30,0,0,0.25);
      border-radius: 0 0 var(--radius) var(--radius);
    }
    .idea-empty-state { text-align:center; padding:60px 20px; color:rgba(207,181,59,0.5); }
    .idea-empty-icon { font-size:64px; margin-bottom:18px; animation:float 4s ease-in-out infinite; }
    .idea-empty-text { font-size:16px; font-weight:600; color:rgba(255,255,255,0.35); }
    .idea-entry {
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:16px; padding:20px 24px;
      background: rgba(255,255,255,0.07);
      backdrop-filter: blur(6px);
      border-radius: var(--radius-sm);
      border: 1.5px solid rgba(207,181,59,0.2);
      border-left: 5px solid var(--gold);
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      transition: all 0.3s ease;
      animation: fadeUp 0.5s ease both;
    }
    .idea-entry:hover {
      transform: translateX(5px) translateY(-2px);
      border-color: rgba(207,181,59,0.5);
      box-shadow: 0 8px 28px rgba(207,181,59,0.2), 0 4px 16px rgba(0,0,0,0.3);
      background: rgba(207,181,59,0.08);
    }
    .idea-num {
      display:inline-flex; align-items:center; justify-content:center;
      width:42px; height:42px; border-radius:50%;
      background: linear-gradient(135deg, var(--maroon), var(--maroon-light));
      color:#fff; font-family:'Nunito',sans-serif; font-weight:900; font-size:16px;
      margin-right:18px; flex-shrink:0;
      box-shadow: 0 4px 14px rgba(139,0,0,0.4);
      animation: bounceIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes bounceIn { 0%{transform:scale(0)}50%{transform:scale(1.1)}100%{transform:scale(1)} }
    .idea-entry-content { flex:1; }
    .idea-entry-text { font-weight:700; color:#fff; font-size:15px; letter-spacing:0.2px; }
    .idea-entry-author { font-size:12px; color:var(--gold-light); font-weight:700; margin-top:4px; letter-spacing:0.5px; }
    .idea-entry-actions { display:flex; gap:8px; align-items:center; margin-left:12px; flex-shrink:0; }
    .idea-like-btn {
      background: linear-gradient(135deg, var(--maroon), var(--maroon-light));
      color:#fff; border:none; border-radius:8px;
      padding:7px 13px; font-size:13px; font-weight:700;
      cursor:pointer; transition:all 0.25s;
      box-shadow: 0 3px 10px rgba(139,0,0,0.3);
      display:flex; align-items:center; gap:5px;
    }
    .idea-like-btn:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(139,0,0,0.45); }
    .idea-like-count {
      display:inline-flex; align-items:center; justify-content:center;
      padding:4px 10px; border-radius:20px;
      background: var(--gold-pale); color:var(--maroon);
      font-size:12px; font-weight:800;
    }
    .idea-like-btn.liked { animation: heartBeat 0.4s ease; }
    @keyframes heartBeat { 0%{transform:scale(1)}50%{transform:scale(1.15)}100%{transform:scale(1)} }
    .idea-del-btn {
      background: rgba(139,0,0,0.3); color:#f87171;
      border: 1px solid rgba(139,0,0,0.4); border-radius:8px;
      padding:7px 12px; font-size:12px; font-weight:700;
      cursor:pointer; transition:all 0.2s; text-transform:uppercase; letter-spacing:0.5px;
    }
    .idea-del-btn:hover { background: rgba(139,0,0,0.6); transform:translateY(-2px); box-shadow:0 4px 12px rgba(139,0,0,0.4); }
    body.dark-mode .idea-stats-bar { background: rgba(10,0,0,0.7); }
    body.dark-mode .idea-input-section { background: rgba(20,0,0,0.5); }
    body.dark-mode .idea-name-select, body.dark-mode .idea-text-input { background:rgba(20,0,0,0.8); }
    body.dark-mode .idea-entry { background: rgba(255,255,255,0.04); }

    @media(max-width:768px){
      .sidebar{display:none}
      .gpa-row{grid-template-columns:80px 1fr 1fr 28px}
      .tt-add{grid-template-columns:1fr 1fr}
      .nav-tabs{gap:3px}
      .nav-tab{padding:7px 10px;font-size:12px}
    }
  </style>
</head>
<body>

<nav class="navbar">
  <div class="brand">
    <div class="brand-logo">
      <img src="data:image/png;base64," alt="UCSC Logo"/>
    </div>
    <div class="brand-name">StudentPro</div>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="show('gpa',this)">GPA Calculator</button>
    <button class="nav-tab" onclick="show('timer',this)">Study Timer</button>
    <button class="nav-tab" onclick="show('todo',this)">Tasks</button>
    <button class="nav-tab" onclick="show('notes',this)">Notes</button>
    <button class="nav-tab" onclick="show('tt',this)">Timetable</button>
    <button class="nav-tab" onclick="show('ideaboard',this)">💡 Group Idea Board</button>
  </div>
  <div class="toggle-wrap">
    <span class="toggle-label" id="toggle-label">🌙 Dark</span>
    <label class="toggle-switch">
      <input type="checkbox" id="dark-toggle" onchange="toggleDark()"/>
      <div class="toggle-track"></div>
      <div class="toggle-thumb" id="toggle-thumb">🌙</div>
    </label>
  </div>
</nav>

<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-label">Task Board</div>
    <div class="task-card"><div class="task-card-title">📝 Assignment 01 Due</div><div class="task-card-date">Sunday, March 15</div></div>
    <div class="task-card"><div class="task-card-title">📖 Mid Semester Exam</div><div class="task-card-date">Sunday, March 22</div></div>
    <div class="task-card"><div class="task-card-title">💻 Web Dev Lab</div><div class="task-card-date">Tuesday, March 18</div></div>
    <div class="task-card"><div class="task-card-title">🎓 Guest Lecture — AI</div><div class="task-card-date">Thursday, March 20</div></div>
    <div class="task-card"><div class="task-card-title">📊 Project Presentation</div><div class="task-card-date">Wednesday, April 01</div></div>
  </aside>

  <main class="main">

    <!-- GPA -->
    <div class="section active" id="gpa">
      <div class="white-card">
        <h2>🎓 GPA Calculator</h2>
        <div id="gpa-rows">
          <div class="gpa-row">
            <span class="gpa-row-label">Course 1</span>
            <input type="number" placeholder="Credits" min="1" max="6"/>
            <input type="number" placeholder="Grade 0–4" min="0" max="4" step="0.1"/>
            <button class="del-btn" onclick="delRow(this)">✕</button>
          </div>
          <div class="gpa-row">
            <span class="gpa-row-label">Course 2</span>
            <input type="number" placeholder="Credits" min="1" max="6"/>
            <input type="number" placeholder="Grade 0–4" min="0" max="4" step="0.1"/>
            <button class="del-btn" onclick="delRow(this)">✕</button>
          </div>
          <div class="gpa-row">
            <span class="gpa-row-label">Course 3</span>
            <input type="number" placeholder="Credits" min="1" max="6"/>
            <input type="number" placeholder="Grade 0–4" min="0" max="4" step="0.1"/>
            <button class="del-btn" onclick="delRow(this)">✕</button>
          </div>
        </div>
        <div class="gpa-actions">
          <button class="btn-ghost" onclick="addCourse()">+ Add Course</button>
          <button class="btn-primary" onclick="calcGPA()">Calculate GPA</button>
        </div>
        <div class="result-card" id="gpa-result"></div>
      </div>
    </div>

    <!-- TIMER -->
    <div class="section" id="timer">
      <div class="white-card">
        <h2>⏱️ Pomodoro Timer</h2>
        <div class="timer-notify" id="timer-notify">🔔 Time's up! Take a well-earned break!</div>
        <div class="timer-modes">
          <button class="mode-chip active" onclick="setMode(25,5,'Pomodoro 25',this)">🍅 Pomodoro 25</button>
          <button class="mode-chip" onclick="setMode(50,10,'Deep Work 50',this)">🧠 Deep Work 50</button>
          <button class="mode-chip" onclick="setMode(15,5,'Short 15',this)">⚡ Short 15</button>
          <button class="mode-chip" onclick="openCustom(this)">⚙️ Custom</button>
        </div>
        <div class="custom-row" id="custom-row" style="display:none">
          <label>Minutes:</label>
          <input type="number" id="custom-min" min="1" max="180" value="30"/>
          <button class="btn-ghost" onclick="applyCustom()">Apply</button>
        </div>
        <div class="timer-face">
          <div class="timer-ring-wrap">
            <svg width="210" height="210" viewBox="0 0 210 210">
              <defs>
                <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#8B0000"/>
                  <stop offset="100%" stop-color="#CFB53B"/>
                </linearGradient>
              </defs>
              <circle class="ring-bg"   cx="105" cy="105" r="92"/>
              <circle class="ring-prog" id="ring-prog" cx="105" cy="105" r="92"
                stroke-dasharray="578" stroke-dashoffset="0"/>
            </svg>
            <div class="timer-inner">
              <div class="timer-digits" id="timer-digits">25:00</div>
              <div class="timer-sub"   id="timer-sub">Pomodoro 25</div>
            </div>
          </div>
          <div class="timer-status-txt" id="timer-status">Session Goal: 25 Minutes</div>
        </div>
        <div class="timer-btns">
          <button class="t-icon-btn t-reset" onclick="resetTimer()" title="Reset">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
            </svg>
          </button>
          <button class="t-icon-btn t-play" id="play-btn" onclick="togglePlay()" title="Play / Pause">
            <svg id="play-icon" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="5,3 19,12 5,21"/>
            </svg>
            <svg id="pause-icon" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" style="display:none">
              <rect x="6" y="4" width="4" height="16" rx="1"/>
              <rect x="14" y="4" width="4" height="16" rx="1"/>
            </svg>
          </button>
          <button class="t-icon-btn t-pause" onclick="pauseTimer()" title="Pause">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <rect x="6" y="4" width="4" height="16" rx="1"/>
              <rect x="14" y="4" width="4" height="16" rx="1"/>
            </svg>
          </button>
        </div>
        <div class="sessions-row">Sessions completed: <b id="scnt">0</b></div>
        <div class="session-dots" id="sdots"></div>
      </div>
    </div>

    <!-- TASKS -->
    <div class="section" id="todo">
      <div class="white-card">
        <h2>✅ Task Manager</h2>
        <div class="todo-add">
          <input type="text" id="todo-input" placeholder="Add a new task…" onkeydown="if(event.key==='Enter')addTodo()"/>
          <select id="todo-pri" style="max-width:120px">
            <option value="high">🔴 High</option>
            <option value="med" selected>🟡 Medium</option>
            <option value="low">🟢 Low</option>
          </select>
          <button class="btn-primary" onclick="addTodo()">Add</button>
        </div>
        <div class="todo-stats" id="todo-stats"></div>
        <div class="todo-filters">
          <button class="fchip active" onclick="setFilter('all',this)">All</button>
          <button class="fchip" onclick="setFilter('active',this)">Active</button>
          <button class="fchip" onclick="setFilter('done',this)">Done</button>
          <button class="fchip" onclick="setFilter('high',this)">🔴 High</button>
        </div>
        <div class="todo-list" id="todo-list"><div class="empty-msg">No tasks yet — add one above!</div></div>
      </div>
    </div>

    <!-- NOTES -->
    <div class="section" id="notes">
      <div class="white-card" style="max-width:640px">
        <h2>📝 Notes</h2>
        <div class="notes-grid" id="notes-grid">
          <div class="empty-msg" style="grid-column:1/-1">No notes yet!</div>
        </div>
        <div class="note-editor" id="note-editor">
          <input type="text" id="note-title" placeholder="Note title…"/>
          <textarea id="note-body" placeholder="Write your note here…"></textarea>
          <div class="note-editor-btns">
            <button class="btn-primary" onclick="saveNote()">💾 Save</button>
            <button class="btn-ghost" onclick="cancelNote()">Cancel</button>
          </div>
        </div>
        <button class="btn-ghost" id="new-note-btn" onclick="newNote()" style="margin-top:4px">+ New Note</button>
      </div>
    </div>

    <!-- TIMETABLE -->
    <div class="section" id="tt">
      <div class="white-card" style="max-width:800px">
        <h2>📅 Course Timetable</h2>
        <div class="tt-add">
          <div><label>Course</label><input type="text" id="tt-course" placeholder="e.g. Data Structures"/></div>
          <div><label>Day</label>
            <select id="tt-day">
              <option>Monday</option><option>Tuesday</option><option>Wednesday</option>
              <option>Thursday</option><option>Friday</option>
            </select>
          </div>
          <div><label>Time</label>
            <select id="tt-time">
              <option>8:00 AM</option><option>9:00 AM</option><option>10:00 AM</option>
              <option>11:00 AM</option><option>12:00 PM</option><option>1:00 PM</option>
              <option>2:00 PM</option><option>3:00 PM</option><option>4:00 PM</option>
              <option>5:00 PM</option>
            </select>
          </div>
          <div><label>Room</label><input type="text" id="tt-room" placeholder="e.g. Lab 3"/></div>
          <button class="btn-primary" onclick="addTT()" style="align-self:end">Add</button>
        </div>
        <div class="tt-wrap"><div class="tt-grid" id="tt-grid"></div></div>
      </div>
    </div>

    <!-- GROUP IDEA BOARD -->
    <div class="section" id="ideaboard">
      <div class="idea-board-wrap">
        <div class="idea-board-header">
          <div class="idea-board-logo">💡</div>
          <div class="idea-board-title">Group Idea Board</div>
        </div>
        <div class="idea-stats-bar">
          <div class="idea-stat-item">
            <div class="idea-stat-label">Total Ideas</div>
            <div class="idea-stat-value" id="ib-idea-count">0</div>
          </div>
          <div class="idea-stat-item">
            <div class="idea-stat-label">Contributors</div>
            <div class="idea-stat-value" id="ib-contrib-count">0</div>
          </div>
          <div class="idea-clear-btn-wrap">
            <button class="idea-clear-btn" onclick="ibClearAll()">🗑️ Clear All</button>
          </div>
        </div>
        <div class="idea-input-section">
          <div class="idea-select-label">👤 Select your name</div>
          <div class="idea-input-row">
            <select class="idea-name-select" id="ib-name">
              <option value="">Select your name…</option>
              <option value="kenula">Kenula</option>
              <option value="rhenold">Rhenold</option>
              <option value="hasindu">Hasindu</option>
              <option value="sinethya">Sinethya</option>
              <option value="ishadi">Ishadi</option>
              <option value="bineth">Bineth</option>
              <option value="venuja">Venuja</option>
              <option value="shemaya">Shemaya</option>
              <option value="lisara">Lisara</option>
              <option value="elakki">Elakki</option>
            </select>
            <input class="idea-text-input" type="text" id="ib-text" placeholder="Enter your idea here…" onkeydown="if(event.key==='Enter')ibAddIdea()"/>
            <button class="idea-add-btn" onclick="ibAddIdea()">Add Idea</button>
          </div>
        </div>
        <div class="ideas-feed" id="ib-feed">
          <div class="idea-empty-state">
            <div class="idea-empty-icon">💭</div>
            <div class="idea-empty-text">No ideas yet — be the first to share one!</div>
          </div>
        </div>
      </div>
    </div>

  </main>
</div>

<script>
// NAV
function show(id,btn){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}

// DARK MODE
function toggleDark(){
  const isDark = document.getElementById('dark-toggle').checked;
  document.body.classList.toggle('dark-mode', isDark);
  document.getElementById('toggle-thumb').textContent = isDark ? '☀️' : '🌙';
  document.getElementById('toggle-label').textContent = isDark ? '☀️ Light' : '🌙 Dark';
}

// GPA
let cc=3;
function addCourse(){
  cc++;
  const r=document.createElement('div'); r.className='gpa-row';
  r.innerHTML=`<span class="gpa-row-label">Course ${cc}</span>
    <input type="number" placeholder="Credits" min="1" max="6"/>
    <input type="number" placeholder="Grade 0–4" min="0" max="4" step="0.1"/>
    <button class="del-btn" onclick="delRow(this)">✕</button>`;
  document.getElementById('gpa-rows').appendChild(r);
}
function delRow(btn){btn.closest('.gpa-row').remove();}
function calcGPA(){
  let pts=0,cr=0;
  document.querySelectorAll('.gpa-row').forEach(r=>{
    const [c,g]=r.querySelectorAll('input');
    const cv=parseFloat(c.value),gv=parseFloat(g.value);
    if(!isNaN(cv)&&!isNaN(gv)){pts+=cv*gv;cr+=cv;}
  });
  const box=document.getElementById('gpa-result');
  box.style.display='block';
  if(!cr){box.innerHTML='<div style="color:#c00;font-weight:700">⚠️ Enter at least one valid course.</div>';return;}
  const gpa=(pts/cr).toFixed(2);
  const level=gpa>=3.7?'🏆 First Class':gpa>=3.3?'🥇 Second Upper':gpa>=3.0?'🥈 Second Lower':gpa>=2.0?'🥉 Pass':'❌ Fail';
  box.innerHTML=`<div class="result-gpa">${gpa}<span style="font-size:20px;color:#9e8ec0"> / 4.00</span></div><div class="result-level">${level}</div>`;
}

// TIMER
const CIRC=2*Math.PI*92;
let totalS,maxS,running=false,tInterval,breakM=5,sessions=0;
function setMode(mins,brk,label,btn){
  document.querySelectorAll('.mode-chip').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active'); breakM=brk;
  totalS=maxS=mins*60;
  document.getElementById('custom-row').style.display='none';
  document.getElementById('timer-sub').textContent=label;
  document.getElementById('timer-status').textContent=`Session Goal: ${mins} Minutes`;
  resetTimer(false);
}
function openCustom(btn){
  document.querySelectorAll('.mode-chip').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('custom-row').style.display='flex';
}
function applyCustom(){
  const m=parseInt(document.getElementById('custom-min').value)||25;
  breakM=5; totalS=maxS=m*60;
  document.getElementById('timer-sub').textContent=`Custom ${m}m`;
  document.getElementById('timer-status').textContent=`Session Goal: ${m} Minutes`;
  resetTimer(false);
}
function updateTD(){
  const m=Math.floor(totalS/60).toString().padStart(2,'0');
  const s=(totalS%60).toString().padStart(2,'0');
  document.getElementById('timer-digits').textContent=`${m}:${s}`;
  const CIRC=2*Math.PI*92;
  document.getElementById('ring-prog').style.strokeDashoffset=CIRC*(1-totalS/maxS);
}
function togglePlay(){
  if(running) pauseTimer(); else startTimer();
}
function setPlayIcon(isPlaying){
  document.getElementById('play-icon').style.display  = isPlaying ? 'none' : '';
  document.getElementById('pause-icon').style.display = isPlaying ? ''     : 'none';
  const btn = document.getElementById('play-btn');
  btn.classList.toggle('paused-state', isPlaying);
}
function startTimer(){
  if(running)return; running=true;
  document.getElementById('timer-notify').style.display='none';
  document.getElementById('timer-status').textContent='🔥 Focusing…';
  setPlayIcon(true);
  tInterval=setInterval(()=>{
    if(totalS<=0){
      clearInterval(tInterval);running=false;sessions++;
      document.getElementById('scnt').textContent=sessions;
      updateDots();
      document.getElementById('timer-notify').style.display='block';
      document.getElementById('timer-status').textContent=`✅ Done! Break: ${breakM} min`;
      setPlayIcon(false);
      return;
    }
    totalS--; updateTD();
  },1000);
}
function pauseTimer(){
  if(!running)return;
  clearInterval(tInterval);running=false;
  document.getElementById('timer-status').textContent='⏸ Paused — press ▶ to continue';
  setPlayIcon(false);
}
function resetTimer(clearN=true){
  clearInterval(tInterval);running=false;totalS=maxS;updateTD();
  if(clearN)document.getElementById('timer-notify').style.display='none';
  document.getElementById('timer-status').textContent=`Session Goal: ${maxS/60} Minutes`;
  setPlayIcon(false);
}
function updateDots(){
  document.getElementById('sdots').innerHTML=
    Array.from({length:Math.min(sessions,8)},()=>`<div class="sdot done"></div>`).join('');
}
(()=>{maxS=totalS=25*60;updateTD();})();

// TODO
let todos=[],todoF='all';
function addTodo(){
  const inp=document.getElementById('todo-input');
  const t=inp.value.trim();if(!t)return;
  todos.push({id:Date.now(),text:t,pri:document.getElementById('todo-pri').value,done:false});
  inp.value='';renderTodos();
}
function setFilter(f,btn){
  todoF=f;
  document.querySelectorAll('.fchip').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');renderTodos();
}
function toggleTodo(id){const t=todos.find(t=>t.id===id);if(t)t.done=!t.done;renderTodos();}
function delTodo(id){todos=todos.filter(t=>t.id!==id);renderTodos();}
function renderTodos(){
  const list=document.getElementById('todo-list');
  const ft=todos.filter(t=>{
    if(todoF==='active')return!t.done;
    if(todoF==='done')return t.done;
    if(todoF==='high')return t.pri==='high';
    return true;
  });
  list.innerHTML=ft.length?ft.map(t=>`
    <div class="todo-item ${t.done?'done':''}">
      <div class="chk ${t.done?'on':''}" onclick="toggleTodo(${t.id})">${t.done?'✓':''}</div>
      <div class="todo-text">${t.text}</div>
      <span class="pri-badge p-${t.pri}">${t.pri==='high'?'High':t.pri==='med'?'Med':'Low'}</span>
      <button class="todo-del" onclick="delTodo(${t.id})">✕</button>
    </div>`).join(''):'<div class="empty-msg">No tasks here!</div>';
  const done=todos.filter(t=>t.done).length;
  document.getElementById('todo-stats').innerHTML=todos.length?
    `<span class="stat-pill">Total <b>${todos.length}</b></span>
     <span class="stat-pill">Done <b>${done}</b></span>
     <span class="stat-pill">Left <b>${todos.length-done}</b></span>`:'';
}

// NOTES
let notes=[],editId=null;
function newNote(){
  editId=null;
  document.getElementById('note-title').value='';
  document.getElementById('note-body').value='';
  document.getElementById('note-editor').classList.add('open');
  document.getElementById('new-note-btn').style.display='none';
}
function saveNote(){
  const title=document.getElementById('note-title').value.trim()||'Untitled';
  const body=document.getElementById('note-body').value.trim();
  if(!body)return;
  if(editId!==null){
    const n=notes.find(n=>n.id===editId);
    if(n){n.title=title;n.body=body;n.date=new Date().toLocaleDateString();}
  }else{
    notes.push({id:Date.now(),title,body,date:new Date().toLocaleDateString()});
  }
  cancelNote();renderNotes();
}
function cancelNote(){
  document.getElementById('note-editor').classList.remove('open');
  document.getElementById('new-note-btn').style.display='';editId=null;
}
function editNote(id){
  const n=notes.find(n=>n.id===id);if(!n)return;
  editId=id;
  document.getElementById('note-title').value=n.title;
  document.getElementById('note-body').value=n.body;
  document.getElementById('note-editor').classList.add('open');
  document.getElementById('new-note-btn').style.display='none';
}
function delNote(id){notes=notes.filter(n=>n.id!==id);renderNotes();}
function renderNotes(){
  const g=document.getElementById('notes-grid');
  g.innerHTML=notes.length?notes.map(n=>`
    <div class="note-card" onclick="editNote(${n.id})">
      <button class="note-del-x" onclick="event.stopPropagation();delNote(${n.id})">✕</button>
      <div class="note-card-title">${n.title}</div>
      <div class="note-card-preview">${n.body}</div>
      <div class="note-card-date">${n.date}</div>
    </div>`).join('')
    :'<div class="empty-msg" style="grid-column:1/-1">No notes yet!</div>';
}

// TIMETABLE
const DAYS=['Monday','Tuesday','Wednesday','Thursday','Friday'];
const TIMES=['8:00 AM','9:00 AM','10:00 AM','11:00 AM','12:00 PM','1:00 PM','2:00 PM','3:00 PM','4:00 PM','5:00 PM'];
let ttData=[];
function buildTT(){
  const g=document.getElementById('tt-grid');
  let h=`<div class="tt-head">Time</div>`+DAYS.map(d=>`<div class="tt-head">${d}</div>`).join('');
  TIMES.forEach(t=>{
    h+=`<div class="tt-time">${t}</div>`;
    DAYS.forEach(d=>{
      const entries=ttData.filter(e=>e.day===d&&e.time===t);
      h+=`<div class="tt-cell">${entries.map(e=>`
        <div class="tt-entry">
          <span>${e.course}${e.room?' · '+e.room:''}</span>
          <button class="tt-entry-del" onclick="delTT(${e.id})">✕</button>
        </div>`).join('')}</div>`;
    });
  });
  g.innerHTML=h;
}
function addTT(){
  const c=document.getElementById('tt-course').value.trim();
  if(!c){document.getElementById('tt-course').focus();return;}
  ttData.push({id:Date.now(),course:c,
    day:document.getElementById('tt-day').value,
    time:document.getElementById('tt-time').value,
    room:document.getElementById('tt-room').value.trim()});
  document.getElementById('tt-course').value='';
  document.getElementById('tt-room').value='';
  buildTT();
}
function delTT(id){ttData=ttData.filter(e=>e.id!==id);buildTT();}
buildTT();

// GROUP IDEA BOARD
let ibIdeas = [], ibCounter = 0, ibLikes = {};

function ibAddIdea() {
  const nameEl = document.getElementById('ib-name');
  const textEl = document.getElementById('ib-text');
  const name = nameEl.value;
  const text = textEl.value.trim();
  if (!name) { alert('Please select your name'); return; }
  if (!text) { alert('Please enter an idea'); return; }
  const displayName = nameEl.options[nameEl.selectedIndex].text;
  ibCounter++;
  ibIdeas.push({ id: ibCounter, text, author: displayName, authorVal: name });
  ibLikes[ibCounter] = [];
  const feed = document.getElementById('ib-feed');
  const empty = feed.querySelector('.idea-empty-state');
  if (empty) empty.remove();
  const el = document.createElement('div');
  el.className = 'idea-entry';
  el.id = `ib-${ibCounter}`;
  el.innerHTML = `
    <div class="idea-num">${ibCounter}</div>
    <div class="idea-entry-content">
      <div class="idea-entry-text">${ibEscape(text)}</div>
      <div class="idea-entry-author">Suggested by ${displayName}</div>
    </div>
    <div class="idea-entry-actions">
      <button class="idea-like-btn" onclick="ibToggleLike(${ibCounter})">
        👍 <span class="idea-like-count" id="iblc-${ibCounter}">0</span>
      </button>
      <button class="idea-del-btn" onclick="ibDelete(${ibCounter})">Delete</button>
    </div>`;
  feed.appendChild(el);
  nameEl.value = ''; textEl.value = ''; textEl.focus();
  ibUpdateStats();
}

function ibToggleLike(id) {
  const person = document.getElementById('ib-name').value;
  if (!person) { alert('Please select your name first'); return; }
  if (!ibLikes[id]) ibLikes[id] = [];
  const idx = ibLikes[id].indexOf(person);
  if (idx > -1) ibLikes[id].splice(idx, 1); else ibLikes[id].push(person);
  const el = document.getElementById(`iblc-${id}`);
  if (el) el.textContent = ibLikes[id].length;
  const btn = document.querySelector(`#ib-${id} .idea-like-btn`);
  if (btn) { btn.classList.add('liked'); setTimeout(() => btn.classList.remove('liked'), 400); }
}

function ibDelete(id) {
  if (!confirm('Delete this idea?')) return;
  const el = document.getElementById(`ib-${id}`);
  if (el) {
    el.style.opacity = '0'; el.style.transform = 'translateX(20px)';
    el.style.transition = 'all 0.3s ease';
    setTimeout(() => {
      el.remove();
      ibIdeas = ibIdeas.filter(i => i.id !== id);
      delete ibLikes[id];
      if (ibIdeas.length === 0) {
        document.getElementById('ib-feed').innerHTML =
          `<div class="idea-empty-state"><div class="idea-empty-icon">💭</div><div class="idea-empty-text">No ideas yet — be the first to share one!</div></div>`;
      }
      ibUpdateStats();
    }, 300);
  }
}

function ibClearAll() {
  if (ibIdeas.length === 0) { alert('No ideas to clear!'); return; }
  if (!confirm('Clear all ideas? This cannot be undone.')) return;
  ibIdeas = []; ibLikes = {}; ibCounter = 0;
  document.getElementById('ib-feed').innerHTML =
    `<div class="idea-empty-state"><div class="idea-empty-icon">💭</div><div class="idea-empty-text">No ideas yet — be the first to share one!</div></div>`;
  ibUpdateStats();
}

function ibUpdateStats() {
  document.getElementById('ib-idea-count').textContent = ibIdeas.length;
  document.getElementById('ib-contrib-count').textContent = new Set(ibIdeas.map(i => i.author)).size;
}

function ibEscape(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
</script>
</body>
</html>
